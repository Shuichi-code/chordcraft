@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark">
        <MudText Typo="Typo.h5" Class="ml-3 cursor-pointer" @onclick="@(() => Navigation.NavigateTo("/"))">
            ChordCraft
        </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/lessons">Lessons</MudButton>
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976d2",
            Secondary = "#424242",
            AppbarBackground = "#2d3748",
            Background = "#f5f7fa",
            Surface = "#ffffff"
        }
    };
}
