@page "/dashboard"
@layout LandingLayout
@inject NavigationManager Navigation
@inject AuthStateService Auth
@inject IClientProgressService Progress

<div class="tw min-h-screen pb-24 antialiased" style="background-color:#F0F4FF; font-family:'Nunito',sans-serif; color:#0D47A1;">

    @* ── Navbar ── *@
    <nav style="background:white; border-bottom:2px solid #E5E7EB; position:sticky; top:0; z-index:50;">
        <div class="max-w-[900px] mx-auto px-6 flex items-center justify-between" style="height:80px;">

            <div class="flex items-center gap-2 cursor-pointer" @onclick='() => Navigation.NavigateTo("/")'>
                <div style="width:40px;height:40px;background:#1565C0;border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 0 0 #0D47A1;">
                    <svg viewBox="0 0 24 24" style="width:22px;height:22px;fill:#FFD54F;"><path d="M13 2L3 14H12L11 22L21 10H12L13 2Z"/></svg>
                </div>
                <span style="color:#1565C0;font-weight:900;font-size:1.5rem;letter-spacing:-0.05em;">ChordCraft</span>
            </div>

            <div class="hidden md:flex items-center gap-8">
                <a href="/lessons" style="color:#1565C0;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;font-size:0.9rem;text-decoration:none;position:relative;">
                    Lessons
                    <span style="position:absolute;bottom:-28px;left:0;width:100%;height:3px;background:#1565C0;border-radius:3px 3px 0 0;"></span>
                </a>
                <a href="/stats" style="color:#9CA3AF;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;font-size:0.9rem;text-decoration:none;">Stats</a>
                <a href="/badges" style="color:#9CA3AF;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;font-size:0.9rem;text-decoration:none;">Badges</a>
            </div>

            <div class="flex items-center gap-4">
                @if (Auth.IsAuthenticated)
                {
                    <span style="font-weight:800;color:#0D47A1;font-size:0.95rem;">@Auth.DisplayName</span>
                    <div style="width:40px;height:40px;border-radius:50%;background:#42A5F5;border:2px solid #E5E7EB;display:flex;align-items:center;justify-content:center;color:white;font-weight:900;">
                        @(Auth.DisplayName?.Length > 0 ? Auth.DisplayName[0].ToString().ToUpper() : "?")
                    </div>
                    <button @onclick="LogoutAsync" style="background:none;border:none;cursor:pointer;font-family:'Nunito',sans-serif;font-weight:800;font-size:0.85rem;color:#9CA3AF;padding:0;text-transform:uppercase;letter-spacing:0.05em;">Log out</button>
                }
                else
                {
                    <a href="/login" style="color:#9CA3AF;font-weight:800;text-decoration:none;">Login</a>
                    <a href="/register" class="btn-accent-nav">Sign Up</a>
                }
            </div>
        </div>
    </nav>

    @* ── Main ── *@
    <main class="max-w-[900px] mx-auto px-4 pt-10 flex flex-col gap-10" style="padding-bottom:60px;">

        @* ── Welcome ── *@
        <section class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h1 style="font-size:clamp(1.8rem,4vw,2.5rem);font-weight:900;color:#0D47A1;letter-spacing:-0.02em;margin-bottom:8px;">
                    Welcome back, @(Auth.DisplayName ?? "Learner")! 👋
                </h1>
                <p style="font-size:1.1rem;font-weight:800;color:#9CA3AF;">Keep your streak alive.</p>
            </div>
            <a href="/lessons" class="db-btn-accent">
                Continue Learning
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </section>

        @* ── Streak / XP / Badges ── *@
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="db-stat-card">
                <div style="width:48px;height:48px;border-radius:16px;background:#FFF3E0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#FF9800" stroke="#F57C00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                </div>
                <div>
                    <div style="font-size:1.5rem;font-weight:900;color:#0D47A1;line-height:1.1;">7</div>
                    <div style="font-size:0.75rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Day Streak</div>
                </div>
            </div>

            <div class="db-stat-card">
                <div style="width:48px;height:48px;border-radius:16px;background:#FFF8E1;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="#FFD54F" stroke="#FBC02D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div>
                    <div style="font-size:1.5rem;font-weight:900;color:#0D47A1;line-height:1.1;">@_totalStars</div>
                    <div style="font-size:0.75rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Total Stars</div>
                </div>
            </div>

            <div class="db-stat-card">
                <div style="width:48px;height:48px;border-radius:16px;background:#E3F2FD;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#42A5F5" stroke="#1E88E5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                </div>
                <div>
                    <div style="font-size:1.5rem;font-weight:900;color:#0D47A1;line-height:1.1;">4</div>
                    <div style="font-size:0.75rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Badges</div>
                </div>
            </div>
        </section>

        @* ── Jump Back In ── *@
        <section>
            <h2 class="db-section-heading">Jump Back In</h2>
            <div class="db-card-lg" style="display:flex;flex-direction:column;gap:24px;position:relative;overflow:hidden;">
                <div style="position:absolute;right:-40px;top:-40px;width:160px;height:160px;background:#F0F4FF;border-radius:50%;opacity:0.5;pointer-events:none;"></div>
                <div style="position:absolute;right:80px;bottom:-40px;width:96px;height:96px;background:#EFF6FF;border-radius:50%;opacity:0.5;pointer-events:none;"></div>

                <div style="position:relative;z-index:1;flex:1;">
                    <div style="display:inline-flex;align-items:center;gap:8px;background:#EFF6FF;color:#42A5F5;padding:4px 12px;border-radius:8px;font-size:0.8rem;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Phase 2: Chords
                    </div>
                    <h3 style="font-size:1.75rem;font-weight:900;color:#0D47A1;letter-spacing:-0.02em;margin-bottom:16px;">Lesson 4: Common Words 1</h3>
                    <div style="max-width:400px;">
                        <div style="display:flex;justify-content:space-between;font-size:0.85rem;font-weight:800;color:#9CA3AF;margin-bottom:8px;">
                            <span>Progress</span><span style="color:#42A5F5;">60%</span>
                        </div>
                        <div style="height:14px;background:#F3F4F6;border-radius:999px;overflow:hidden;">
                            <div style="height:100%;width:60%;background:#42A5F5;border-radius:999px;"></div>
                        </div>
                    </div>
                </div>

                <div style="position:relative;z-index:1;">
                    <a href="/lessons/4" class="db-btn-accent">Resume</a>
                </div>
            </div>
        </section>

        @* ── Phase Progress ── *@
        <section>
            <h2 class="db-section-heading">Your Progress</h2>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-3">

                @* Phase 1 — complete *@
                <div class="db-phase-card" style="cursor:pointer;" @onclick='() => Navigation.NavigateTo("/lessons")'>
                    <div class="db-ring-wrap">
                        <svg viewBox="0 0 100 100" style="width:72px;height:72px;">
                            <circle cx="50" cy="50" r="40" fill="none" stroke="#E5E7EB" stroke-width="8"/>
                            <circle cx="50" cy="50" r="40" fill="none" stroke="#42A5F5" stroke-width="8" stroke-linecap="round"
                                    stroke-dasharray="251.2" stroke-dashoffset="0" class="db-ring"/>
                        </svg>
                        <div class="db-ring-inner">
                            <div style="width:36px;height:36px;background:#42A5F5;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                        </div>
                    </div>
                    <h4 style="font-weight:900;color:#0D47A1;font-size:1rem;">Phase 1</h4>
                    <span style="font-size:0.7rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;">10/10 Lessons</span>
                </div>

                @* Phase 2 — current *@
                <div class="db-phase-card" style="border-color:#1565C0;border-bottom:4px solid #1565C0;box-shadow:0 4px 0 0 #1565C0;cursor:pointer;position:relative;" @onclick='() => Navigation.NavigateTo("/lessons")'>
                    <div style="position:absolute;top:-14px;background:#1565C0;color:white;font-size:0.65rem;font-weight:900;text-transform:uppercase;letter-spacing:0.1em;padding:3px 12px;border-radius:999px;border:2px solid white;">Current</div>
                    <div class="db-ring-wrap" style="margin-top:8px;">
                        <svg viewBox="0 0 100 100" style="width:72px;height:72px;">
                            <circle cx="50" cy="50" r="40" fill="none" stroke="#E5E7EB" stroke-width="8"/>
                            <circle cx="50" cy="50" r="40" fill="none" stroke="#42A5F5" stroke-width="8" stroke-linecap="round"
                                    stroke-dasharray="251.2" stroke-dashoffset="100.48" class="db-ring"/>
                        </svg>
                        <div class="db-ring-inner">
                            <span style="font-weight:900;font-size:1.25rem;color:#1565C0;">2</span>
                        </div>
                    </div>
                    <h4 style="font-weight:900;color:#0D47A1;font-size:1rem;">Phase 2</h4>
                    <span style="font-size:0.7rem;font-weight:800;color:#1565C0;text-transform:uppercase;">3/5 Lessons</span>
                </div>

                @* Phases 3–5 — locked *@
                @foreach (var (label, total) in new[] { ("Phase 3","0/8"), ("Phase 4","0/12"), ("Phase 5","0/15") })
                {
                    <div class="db-phase-card" style="background:#F9FAFB;opacity:0.8;cursor:not-allowed;">
                        <div class="db-ring-wrap">
                            <svg viewBox="0 0 100 100" style="width:72px;height:72px;">
                                <circle cx="50" cy="50" r="40" fill="none" stroke="#E5E7EB" stroke-width="8"/>
                            </svg>
                            <div class="db-ring-inner">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            </div>
                        </div>
                        <h4 style="font-weight:900;color:#9CA3AF;font-size:1rem;">@label</h4>
                        <span style="font-size:0.7rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;">@total Lessons</span>
                    </div>
                }
            </div>
        </section>

        @* ── Recent Achievements ── *@
        <section>
            <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:16px;">
                <h2 class="db-section-heading" style="margin-bottom:0;">Recent Achievements</h2>
                <a href="/badges" style="color:#1565C0;font-weight:800;font-size:0.8rem;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;">View All</a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="db-badge-card">
                    <div style="width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#FFD54F,#F57C00);box-shadow:0 0 24px rgba(255,213,79,0.6);display:flex;align-items:center;justify-content:center;margin-bottom:16px;border:4px solid white;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="white"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                    </div>
                    <h4 style="font-weight:900;color:#0D47A1;font-size:1rem;margin-bottom:4px;">First Blood</h4>
                    <span style="font-size:0.75rem;font-weight:800;color:#9CA3AF;">Earned 6 days ago</span>
                </div>

                <div class="db-badge-card">
                    <div style="width:88px;height:88px;border-radius:50%;background:linear-gradient(135deg,#42A5F5,#1565C0);box-shadow:0 0 24px rgba(66,165,245,0.4);display:flex;align-items:center;justify-content:center;margin-bottom:16px;border:4px solid white;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    </div>
                    <h4 style="font-weight:900;color:#0D47A1;font-size:1rem;margin-bottom:4px;">Speed Demon</h4>
                    <span style="font-size:0.75rem;font-weight:800;color:#9CA3AF;">Earned 2 days ago</span>
                </div>

                <div class="db-badge-card" style="opacity:0.7;cursor:not-allowed;">
                    <div style="width:88px;height:88px;border-radius:50%;background:#E5E7EB;display:flex;align-items:center;justify-content:center;margin-bottom:16px;border:4px solid #D1D5DB;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3m0 12l-4-4m4 4l4-4M2 17l.621 2.485A2 2 0 0 0 4.561 21h14.878a2 2 0 0 0 1.94-1.515L22 17"/></svg>
                    </div>
                    <h4 style="font-weight:900;color:#9CA3AF;font-size:1rem;margin-bottom:4px;">Perfect Score</h4>
                    <span style="font-size:0.75rem;font-weight:800;color:#9CA3AF;">Locked</span>
                </div>
            </div>
        </section>

        @* ── Quick Stats ── *@
        <section>
            <h2 class="db-section-heading">Quick Stats</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="db-stat-row">
                    <div style="width:56px;height:56px;border-radius:16px;background:#E8F5E9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#43A047" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:900;color:#0D47A1;line-height:1;">94%</div>
                        <div style="font-size:0.8rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Overall Accuracy</div>
                    </div>
                </div>

                <div class="db-stat-row">
                    <div style="width:56px;height:56px;border-radius:16px;background:#FFF3E0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F57C00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:900;color:#0D47A1;line-height:1;">42 WPM</div>
                        <div style="font-size:0.8rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Average Speed</div>
                    </div>
                </div>

                <div class="db-stat-row">
                    <div style="width:56px;height:56px;border-radius:16px;background:#F3E5F5;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8E24AA" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:900;color:#0D47A1;line-height:1;">14h 20m</div>
                        <div style="font-size:0.8rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Total Practice Time</div>
                    </div>
                </div>

                <div class="db-stat-row">
                    <div style="width:56px;height:56px;border-radius:16px;background:#E3F2FD;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1E88E5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div>
                        <div style="font-size:2rem;font-weight:900;color:#0D47A1;line-height:1;">@_lessonsCompleted</div>
                        <div style="font-size:0.8rem;font-weight:800;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.08em;">Lessons Completed</div>
                    </div>
                </div>
            </div>
        </section>

    </main>
</div>

@code {
    private int _totalStars;
    private int _lessonsCompleted;

    protected override async Task OnInitializedAsync()
    {
        _totalStars = await Progress.GetTotalStarsAsync();
        // Approximate: count lessons where best stars >= 1
        // TODO: replace with dedicated API call when available
        _lessonsCompleted = 13;
    }

    private async Task LogoutAsync()
    {
        await Auth.ClearAsync();
        Navigation.NavigateTo("/");
    }
}
