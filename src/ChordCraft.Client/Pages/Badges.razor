@page "/badges"
@layout LandingLayout
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using ChordCraft.Core.DTOs.Badges
@inject HttpClient Http
@inject AuthStateService Auth
@inject NavigationManager Navigation

<div class="bg-page">

    @* ── Navbar ── *@
    <nav class="bg-nav">
        <div class="bg-nav-inner">
            <div class="bg-logo" @onclick='() => Navigation.NavigateTo("/")'>
                <div class="bg-logo-icon">
                    <svg viewBox="0 0 24 24"><path d="M13 2L3 14H12L11 22L21 10H12L13 2Z"/></svg>
                </div>
                ChordCraft
            </div>
            <div class="bg-nav-links">
                <a href="/lessons" class="bg-nav-link">Lessons</a>
                <a href="/stats" class="bg-nav-link">Stats</a>
                <a href="/badges" class="bg-nav-link bg-nav-link-active">Badges</a>
            </div>
            <div class="bg-nav-right">
                @if (Auth.IsAuthenticated)
                {
                    <span class="bg-username">@Auth.DisplayName</span>
                    <div class="bg-avatar">@(Auth.DisplayName?.Length > 0 ? Auth.DisplayName[0].ToString().ToUpper() : "?")</div>
                    <button @onclick="LogoutAsync" class="bg-logout-btn">Log out</button>
                }
                else
                {
                    <a href="/login" class="bg-nav-link">Login</a>
                    <a href="/register" class="bg-signup-btn">Sign Up</a>
                }
            </div>
        </div>
    </nav>

    <main class="bg-main">
        <h1 class="bg-page-title">Badges</h1>

        @if (!Auth.IsAuthenticated)
        {
            <div class="bg-auth-banner">
                <p>Sign up to earn badges and track achievements.</p>
                <div class="bg-auth-actions">
                    <a href="/register" class="bg-btn-accent">Sign Up Free</a>
                    <a href="/login" class="bg-btn-outline">Log In</a>
                </div>
            </div>
            <div class="bg-grid">
                @for (int i = 0; i < 8; i++)
                {
                    <div class="bg-badge-card bg-badge-locked">
                        <div class="bg-badge-icon bg-badge-icon-locked">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="2" width="32" height="32"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <span class="bg-badge-name" style="color:#D1D5DB;">???</span>
                    </div>
                }
            </div>
        }
        else if (_loading)
        {
            <div class="bg-loading"><div class="bg-spinner"></div></div>
        }
        else if (_badges is not null)
        {
            var earned = _badges.Where(b => b.Earned).ToList();
            var unearned = _badges.Where(b => !b.Earned).ToList();

            @if (earned.Count > 0)
            {
                <h2 class="bg-section-title">Earned (@earned.Count)</h2>
                <div class="bg-grid bg-grid-mb">
                    @foreach (var badge in earned)
                    {
                        <div class="bg-badge-card bg-badge-earned">
                            <div class="bg-badge-icon bg-badge-icon-earned">
                                <svg viewBox="0 0 24 24" fill="#FFD54F" stroke="#F57F17" stroke-width="1.5" width="32" height="32"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                            </div>
                            <span class="bg-badge-name">@badge.Name</span>
                            <span class="bg-badge-desc">@badge.Description</span>
                            @if (badge.EarnedAt.HasValue)
                            {
                                <span class="bg-badge-date">@badge.EarnedAt.Value.ToString("MMM dd, yyyy")</span>
                            }
                        </div>
                    }
                </div>
            }

            <h2 class="bg-section-title">Not Yet Earned (@unearned.Count)</h2>
            <div class="bg-grid">
                @foreach (var badge in unearned)
                {
                    <div class="bg-badge-card bg-badge-locked">
                        <div class="bg-badge-icon bg-badge-icon-locked">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="2" width="28" height="28"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <span class="bg-badge-name" style="color:#9CA3AF;">@badge.Name</span>
                        <span class="bg-badge-desc">@badge.Description</span>
                    </div>
                }
            </div>
        }
    </main>
</div>

@code {
    private List<BadgeDto>? _badges;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) { _loading = false; return; }
        try
        {
            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", Auth.Token);
            _badges = await Http.GetFromJsonAsync<List<BadgeDto>>("api/badges");
        }
        finally { _loading = false; }
    }

    private async Task LogoutAsync()
    {
        await Auth.ClearAsync();
        Navigation.NavigateTo("/");
    }
}
