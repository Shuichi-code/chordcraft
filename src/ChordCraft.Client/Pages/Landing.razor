@page "/"
@layout LandingLayout
@inject NavigationManager Navigation
@inject AuthStateService Auth

<div class="landing">

    @* ── Navbar ── *@
    <header class="navbar">
        <div class="container flex-between">
            <a href="/" class="logo">
                <svg viewBox="0 0 24 24"><path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" /></svg>
                ChordCraft
            </a>
            <nav class="nav-links">
                <a href="/lessons">Learn</a>
                <a href="/stats">Stats</a>
                <a href="/badges">Badges</a>
            </nav>
            @if (Auth.IsAuthenticated)
            {
                <a href="/lessons" class="btn btn-accent">Continue</a>
            }
            else
            {
                <a href="/register" class="btn btn-accent">Sign Up</a>
            }
        </div>
    </header>

    @* ── Hero ── *@
    <section class="hero container">
        <div class="hero-card">
            <div class="hero-content">
                @if (Auth.IsAuthenticated)
                {
                    <p class="hero-overline">WELCOME BACK, @Auth.DisplayName!</p>
                }
                else
                {
                    <p class="hero-overline">YOUR CHARACHORDER JOURNEY</p>
                }
                <h1>Master the <span class="accent-text">Speed</span> of Thought.</h1>
                <p class="hero-sub">Learn to type faster than a standard keyboard — one chord at a time. The gamified way to master the CharaChorder.</p>
                <a href="/lessons" class="btn btn-accent">
                    @(Auth.IsAuthenticated ? "Continue Learning" : "Start Learning Free →")
                </a>
            </div>
            <div class="hero-visual">
                <svg viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="20" y="80" width="160" height="180" rx="40" fill="#42A5F5" />
                    <rect x="20" y="80" width="160" height="170" rx="40" fill="#2196F3" />
                    <circle cx="140" cy="140" r="30" fill="#0D47A1" />
                    <circle cx="135" cy="135" r="20" fill="#1976D2" />
                    <rect x="40" y="100" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="40" y="100" width="20" height="35" rx="10" fill="#FFF176" />
                    <rect x="70" y="90" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="70" y="90" width="20" height="35" rx="10" fill="#FFF176" />
                    <rect x="100" y="100" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="100" y="100" width="20" height="35" rx="10" fill="#FFF176" />
                    <rect x="220" y="80" width="160" height="180" rx="40" fill="#42A5F5" />
                    <rect x="220" y="80" width="160" height="170" rx="40" fill="#2196F3" />
                    <circle cx="260" cy="140" r="30" fill="#0D47A1" />
                    <circle cx="265" cy="135" r="20" fill="#1976D2" />
                    <rect x="340" y="100" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="340" y="100" width="20" height="35" rx="10" fill="#FFF176" />
                    <rect x="310" y="90" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="310" y="90" width="20" height="35" rx="10" fill="#FFF176" />
                    <rect x="280" y="100" width="20" height="40" rx="10" fill="#FFD54F" />
                    <rect x="280" y="100" width="20" height="35" rx="10" fill="#FFF176" />
                    <path d="M200 20 L205 40 L225 45 L205 50 L200 70 L195 50 L175 45 L195 40 Z" fill="#FFD54F" />
                    <path d="M50 40 L53 50 L63 53 L53 56 L50 66 L47 56 L37 53 L47 50 Z" fill="#FFFFFF" opacity="0.8" />
                    <path d="M350 220 L353 230 L363 233 L353 236 L350 246 L347 236 L337 233 L347 230 Z" fill="#FFFFFF" opacity="0.8" />
                    <path d="M185 150 L205 130 H195 L215 110" stroke="#FFD54F" stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
        </div>
    </section>

    @* ── Stats bar ── *@
    <div class="container stats-wrapper">
        <div class="stats-container">
            <div class="stat-pill">
                <svg viewBox="0 0 24 24" fill="#42A5F5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z" /></svg>
                18 Switches
            </div>
            <div class="stat-pill">
                <svg viewBox="0 0 24 24" fill="#42A5F5"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9H9V9h10v2zm-4 4H9v-2h6v2zm4-8H9V5h10v2z" /></svg>
                160+ Lessons
            </div>
            <div class="stat-pill">
                <svg viewBox="0 0 24 24" fill="#FFD54F"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm3.3 14.71L11 12.41V7h2v4.59l3.71 3.71-1.42 1.41z" /></svg>
                5× Faster than QWERTY
            </div>
        </div>
    </div>

    @* ── How it works ── *@
    <section class="how-it-works container" id="learn">
        <h2>How it works</h2>
        <div class="steps-grid">
            <div class="card step-card">
                <div class="step-icon-wrapper">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1565C0" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="4" /><path d="M9 3v18" /><path d="M15 3v18" />
                    </svg>
                </div>
                <h3>1. Learn the Layout</h3>
                <p>Master the 18 directional switches through bite-sized, intuitive drills.</p>
            </div>
            <div class="card step-card">
                <div class="step-icon-wrapper step-icon-blue">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#42A5F5" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2v20" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </div>
                <h3>2. Practice Chords</h3>
                <p>Press multiple switches simultaneously to output entire words instantly.</p>
            </div>
            <div class="card step-card">
                <div class="step-icon-wrapper step-icon-yellow">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#F57F17" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                </div>
                <h3>3. Earn Stars</h3>
                <p>Hit accuracy goals to 3-star lessons and unlock advanced chord libraries.</p>
                <div class="star-rating">
                    <svg viewBox="0 0 24 24" fill="#FFD54F"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    <svg viewBox="0 0 24 24" fill="#FFD54F"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    <svg viewBox="0 0 24 24" fill="#FFD54F"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    <svg viewBox="0 0 24 24" fill="#FFD54F"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                    <svg viewBox="0 0 24 24" fill="#E2E8F0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                </div>
            </div>
        </div>
    </section>

    @* ── Phases ── *@
    <section class="phases-section">
        <div class="container phases-header">
            <h2>The Path to Chording</h2>
        </div>
        <div class="phases-scroll-container">
            <div class="phase-card">
                <div class="phase-badge">
                    <svg viewBox="0 0 24 24" fill="#42A5F5"><circle cx="12" cy="12" r="10" /></svg>
                    Phase 1
                </div>
                <h3>Foundation</h3>
                <p>Character entry and basic 3D spatial awareness.</p>
            </div>
            <div class="phase-card">
                <div class="phase-badge">
                    <svg viewBox="0 0 24 24" fill="#42A5F5"><polygon points="12 2 22 22 2 22" /></svg>
                    Phase 2
                </div>
                <h3>Bigrams</h3>
                <p>Common two-letter combinations rolled into single actions.</p>
            </div>
            <div class="phase-card">
                <div class="phase-badge">
                    <svg viewBox="0 0 24 24" fill="#42A5F5"><rect x="3" y="3" width="18" height="18" rx="2" /></svg>
                    Phase 3
                </div>
                <h3>Core Chords</h3>
                <p>The top 100 most used English words, typed instantly.</p>
            </div>
            <div class="phase-card">
                <div class="phase-badge">
                    <svg viewBox="0 0 24 24" fill="#42A5F5"><polygon points="12 2 22 12 12 22 2 12" /></svg>
                    Phase 4
                </div>
                <h3>Fluidity</h3>
                <p>Transitioning seamlessly between character entry and chording.</p>
            </div>
            <div class="phase-card">
                <div class="phase-badge">
                    <svg viewBox="0 0 24 24" fill="#42A5F5"><path d="M12 2 L22 8 L22 16 L12 22 L2 16 L2 8 Z" /></svg>
                    Phase 5
                </div>
                <h3>Godspeed</h3>
                <p>Custom chord creation and breaking 200+ WPM.</p>
            </div>
        </div>
    </section>

    @* ── Gamification ── *@
    <section class="gamification container" id="badges">
        <div class="gami-grid">
            <div class="gami-mockup">
                <div class="gami-mockup-inner">
                    <div class="mock-header"></div>
                    <div class="mock-row">
                        <div class="mock-box"><div class="mock-switch"></div></div>
                        <div class="mock-box mock-box-active"><div class="mock-circle"></div></div>
                    </div>
                    <div class="mock-row">
                        <div class="mock-box"><div class="mock-switch"></div></div>
                        <div class="mock-box"><div class="mock-switch"></div></div>
                    </div>
                </div>
            </div>
            <div class="gami-content">
                <h2>Level up your muscle memory.</h2>
                <p>Typing practice doesn't have to be boring. We've built an addictive engine to keep you pushing your WPM higher.</p>
                <ul class="gami-list">
                    <li>
                        <div class="check-icon"><svg viewBox="0 0 24 24" fill="#8D6E00"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg></div>
                        Daily streaks and XP goals
                    </li>
                    <li>
                        <div class="check-icon"><svg viewBox="0 0 24 24" fill="#8D6E00"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg></div>
                        Unlockable badges for speed milestones
                    </li>
                    <li>
                        <div class="check-icon"><svg viewBox="0 0 24 24" fill="#8D6E00"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg></div>
                        Global leaderboards by chord count
                    </li>
                    <li>
                        <div class="check-icon"><svg viewBox="0 0 24 24" fill="#8D6E00"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" /></svg></div>
                        Interactive heatmap of your slowest switches
                    </li>
                </ul>
            </div>
        </div>
    </section>

    @* ── Footer CTA ── *@
    <footer class="footer-cta">
        <div class="footer-content container">
            <h2>Your fingers are faster than you think.</h2>
            <a href="/register" class="btn btn-accent">Get Started</a>
        </div>
    </footer>

</div>

@code {
}
