@page "/"
@using MudBlazor
@using ChordCraft.Core.DTOs.Lessons
@inject LessonDataService LessonData
@inject NavigationManager Navigation
@inject AuthStateService Auth

<MudContainer MaxWidth="MaxWidth.Large" Class="pt-4 pb-8">

    @* ── Hero ── *@
    <MudPaper Elevation="0" Style="background: linear-gradient(135deg, #1565c0 0%, #1976d2 60%, #42a5f5 100%);
                                   border-radius: 28px; padding: 48px 40px; margin-bottom: 32px;">
        <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.7); font-weight: 800; letter-spacing: 0.12em;">
            @if (Auth.IsAuthenticated)
            {
                <span>WELCOME BACK, @Auth.DisplayName!</span>
            }
            else
            {
                <span>YOUR CHARACHORDER JOURNEY</span>
            }
        </MudText>
        <MudText Typo="Typo.h3" Style="color: #ffffff; font-weight: 900; line-height: 1.15; margin: 8px 0 16px; max-width: 520px;">
            Master the <span style="color: #ffd54f;">Speed</span> of Thought.
        </MudText>
        <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.85); max-width: 480px; margin-bottom: 28px; font-weight: 600;">
            Learn to type faster than a standard keyboard — one chord at a time.
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Style="background: #f59e0b; color: #1e293b; font-weight: 900; font-size: 1.1rem; padding: 14px 32px; border-radius: 16px;"
                   Size="Size.Large"
                   Href="/lessons"
                   StartIcon="@Icons.Material.Filled.PlayArrow">
            @(Auth.IsAuthenticated ? "Continue Learning" : "Start Learning")
        </MudButton>
    </MudPaper>

    @* ── Phase cards ── *@
    @if (phases is null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="d-block mx-auto mt-8" />
    }
    else
    {
        <MudText Typo="Typo.h6" Style="font-weight: 900; color: #1e293b; margin-bottom: 16px;">Learning Phases</MudText>
        <MudGrid Spacing="3">
            @foreach (var phase in phases)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="1"
                              Class="cursor-pointer"
                              Style="border-radius: 20px; padding: 24px; transition: box-shadow 0.2s;"
                              @onclick="@(() => Navigation.NavigateTo("/lessons"))">
                        <MudText Typo="Typo.overline" Color="Color.Primary" Style="font-weight: 800;">Phase @phase.Id</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight: 900; color: #1e293b; margin: 4px 0 8px;">@phase.Name</MudText>
                        <MudText Typo="Typo.body2" Style="color: #64748b;">@(phase.Description ?? "")</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

</MudContainer>

@code {
    private List<PhaseDto>? phases;

    protected override async Task OnInitializedAsync()
    {
        phases = await LessonData.GetPhasesAsync();
    }
}
