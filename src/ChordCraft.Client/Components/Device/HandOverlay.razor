<svg viewBox="0 0 800 320" class="hand-overlay" xmlns="http://www.w3.org/2000/svg"
     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">

    <defs>
        <marker id="arrowhead-hand" markerWidth="6" markerHeight="4" refX="6" refY="2" orient="auto">
            <polygon points="0 0, 6 2, 0 4" fill="#1976d2" />
        </marker>
    </defs>

    @* ── Left hand ── *@

    @* Palm rendered first (behind fingers) *@
    <path d="M 28 222 L 278 222 Q 292 222 292 248 Q 292 282 270 288 L 32 288 Q 12 288 12 262 Q 12 222 28 222 Z"
          fill="rgba(210,210,210,0.35)" stroke="rgba(150,150,150,0.55)" stroke-width="1.5" />

    @* Left fingers *@
    @foreach (var f in LeftFingers)
    {
        var isActive = ActiveFingers.Contains(f.Id);
        <path d="@f.PathData"
              fill="@(isActive ? "rgba(25,118,210,0.65)" : "rgba(220,220,220,0.5)")"
              stroke="@(isActive ? "#1565c0" : "rgba(150,150,150,0.7)")"
              stroke-width="@(isActive ? "2" : "1.5")"
              style="transition: fill 0.2s, stroke 0.2s;" />
        @if (isActive && ActiveDirection.HasValue && ActiveDirection.Value != SwitchDirection.Push)
        {
            var (dx, dy) = GetArrowOffset(ActiveDirection.Value);
            <line x1="@f.Cx" y1="@f.Ty"
                  x2="@(f.Cx + dx)" y2="@(f.Ty + dy)"
                  stroke="#1976d2" stroke-width="2.5" stroke-linecap="round"
                  marker-end="url(#arrowhead-hand)" />
        }
    }

    @* ── Right hand ── *@

    @* Palm *@
    <path d="M 772 222 L 522 222 Q 508 222 508 248 Q 508 282 530 288 L 768 288 Q 788 288 788 262 Q 788 222 772 222 Z"
          fill="rgba(210,210,210,0.35)" stroke="rgba(150,150,150,0.55)" stroke-width="1.5" />

    @* Right fingers *@
    @foreach (var f in RightFingers)
    {
        var isActive = ActiveFingers.Contains(f.Id);
        <path d="@f.PathData"
              fill="@(isActive ? "rgba(25,118,210,0.65)" : "rgba(220,220,220,0.5)")"
              stroke="@(isActive ? "#1565c0" : "rgba(150,150,150,0.7)")"
              stroke-width="@(isActive ? "2" : "1.5")"
              style="transition: fill 0.2s, stroke 0.2s;" />
        @if (isActive && ActiveDirection.HasValue && ActiveDirection.Value != SwitchDirection.Push)
        {
            var (dx, dy) = GetArrowOffset(ActiveDirection.Value);
            <line x1="@f.Cx" y1="@f.Ty"
                  x2="@(f.Cx + dx)" y2="@(f.Ty + dy)"
                  stroke="#1976d2" stroke-width="2.5" stroke-linecap="round"
                  marker-end="url(#arrowhead-hand)" />
        }
    }

</svg>

@code {
    [Parameter] public List<SwitchId> ActiveFingers { get; set; } = [];
    [Parameter] public SwitchDirection? ActiveDirection { get; set; }

    // Each finger: rounded-rectangle path from palm top (y=222) up to its switch tip.
    // Path formula: M (cx-hw) 222  L (cx-hw) (ty+hw)  A hw hw 0 0 0 (cx+hw) (ty+hw)  L (cx+hw) 222  Z
    private record FingerDef(SwitchId Id, int Cx, int Ty, string PathData);

    private static readonly List<FingerDef> LeftFingers =
    [
        new(SwitchId.L_Pinky,   50, 100, "M 39 222 L 39 111 A 11 11 0 0 0 61 111 L 61 222 Z"),
        new(SwitchId.L_Ring,   110,  80, "M 99 222 L 99 91 A 11 11 0 0 0 121 91 L 121 222 Z"),
        new(SwitchId.L_Middle, 170,  65, "M 159 222 L 159 76 A 11 11 0 0 0 181 76 L 181 222 Z"),
        new(SwitchId.L_Index,  230,  80, "M 219 222 L 219 91 A 11 11 0 0 0 241 91 L 241 222 Z"),
        new(SwitchId.L_Thumb,  268, 148, "M 257 222 L 257 159 A 11 11 0 0 0 279 159 L 279 222 Z"),
    ];

    private static readonly List<FingerDef> RightFingers =
    [
        new(SwitchId.R_Thumb,  532, 148, "M 521 222 L 521 159 A 11 11 0 0 0 543 159 L 543 222 Z"),
        new(SwitchId.R_Index,  570,  80, "M 559 222 L 559 91 A 11 11 0 0 0 581 91 L 581 222 Z"),
        new(SwitchId.R_Middle, 630,  65, "M 619 222 L 619 76 A 11 11 0 0 0 641 76 L 641 222 Z"),
        new(SwitchId.R_Ring,   690,  80, "M 679 222 L 679 91 A 11 11 0 0 0 701 91 L 701 222 Z"),
        new(SwitchId.R_Pinky,  750, 100, "M 739 222 L 739 111 A 11 11 0 0 0 761 111 L 761 222 Z"),
    ];

    private static (int X, int Y) GetArrowOffset(SwitchDirection dir) => dir switch
    {
        SwitchDirection.Up    => (0,  -22),
        SwitchDirection.Down  => (0,   22),
        SwitchDirection.Left  => (-22,  0),
        SwitchDirection.Right => (22,   0),
        _ => (0, 0)
    };
}
