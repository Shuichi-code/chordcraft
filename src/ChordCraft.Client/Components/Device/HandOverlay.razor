<svg viewBox="0 0 800 320" class="hand-overlay" xmlns="http://www.w3.org/2000/svg"
     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">

    <defs>
        <marker id="arrowhead-hand" markerWidth="6" markerHeight="4" refX="6" refY="2" orient="auto">
            <polygon points="0 0, 6 2, 0 4" fill="#1976d2" />
        </marker>
    </defs>

    @* ── Left hand (compact, realistic proportions) ── *@

    @* Palm *@
    <rect x="83" y="292" width="124" height="22" rx="11"
          fill="rgba(210,210,210,0.4)" stroke="rgba(150,150,150,0.5)" stroke-width="1.5" />

    @foreach (var f in LeftFingers)
    {
        var isActive = ActiveFingers.Contains(f.Id);
        <path d="@FingerPath(f.Cx, f.Tip)"
              fill="@(isActive ? "rgba(25,118,210,0.65)" : "rgba(220,220,220,0.55)")"
              stroke="@(isActive ? "#1565c0" : "rgba(150,150,150,0.7)")"
              stroke-width="@(isActive ? "2" : "1.5")"
              style="transition: fill 0.2s, stroke 0.2s;" />

        @if (isActive)
        {
            @* Dashed line from finger tip to switch circle *@
            <line x1="@f.Cx" y1="@f.Tip"
                  x2="@f.SwitchCx" y2="@f.SwitchCy"
                  stroke="#1976d2" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.65" />

            @* Direction arrow at the switch *@
            @if (ActiveDirection.HasValue)
            {
                var (dx, dy) = GetArrowOffset(ActiveDirection.Value);
                <line x1="@f.SwitchCx" y1="@f.SwitchCy"
                      x2="@(f.SwitchCx + dx)" y2="@(f.SwitchCy + dy)"
                      stroke="#1976d2" stroke-width="2.5" stroke-linecap="round"
                      marker-end="url(#arrowhead-hand)" />
            }
        }
    }

    @* ── Right hand ── *@

    <rect x="593" y="292" width="124" height="22" rx="11"
          fill="rgba(210,210,210,0.4)" stroke="rgba(150,150,150,0.5)" stroke-width="1.5" />

    @foreach (var f in RightFingers)
    {
        var isActive = ActiveFingers.Contains(f.Id);
        <path d="@FingerPath(f.Cx, f.Tip)"
              fill="@(isActive ? "rgba(25,118,210,0.65)" : "rgba(220,220,220,0.55)")"
              stroke="@(isActive ? "#1565c0" : "rgba(150,150,150,0.7)")"
              stroke-width="@(isActive ? "2" : "1.5")"
              style="transition: fill 0.2s, stroke 0.2s;" />

        @if (isActive)
        {
            <line x1="@f.Cx" y1="@f.Tip"
                  x2="@f.SwitchCx" y2="@f.SwitchCy"
                  stroke="#1976d2" stroke-width="1.5" stroke-dasharray="5 3" opacity="0.65" />

            @if (ActiveDirection.HasValue)
            {
                var (dx, dy) = GetArrowOffset(ActiveDirection.Value);
                <line x1="@f.SwitchCx" y1="@f.SwitchCy"
                      x2="@(f.SwitchCx + dx)" y2="@(f.SwitchCy + dy)"
                      stroke="#1976d2" stroke-width="2.5" stroke-linecap="round"
                      marker-end="url(#arrowhead-hand)" />
            }
        }
    }

</svg>

@code {
    [Parameter] public List<SwitchId> ActiveFingers { get; set; } = [];
    [Parameter] public SwitchDirection? ActiveDirection { get; set; }

    // Compact hand positions (Cx/Tip) are independent of switch positions.
    // The dashed line bridges the two.
    private record FingerDef(SwitchId Id, int Cx, int Tip, int SwitchCx, int SwitchCy);

    private static readonly List<FingerDef> LeftFingers =
    [
        new(SwitchId.L_Pinky,   100, 243,  50, 100),
        new(SwitchId.L_Ring,    122, 233, 110,  80),
        new(SwitchId.L_Middle,  144, 225, 170,  65),
        new(SwitchId.L_Index,   166, 233, 230,  80),
        new(SwitchId.L_Thumb,   190, 258, 268, 148),
    ];

    private static readonly List<FingerDef> RightFingers =
    [
        new(SwitchId.R_Thumb,  610, 258, 532, 148),
        new(SwitchId.R_Index,  634, 233, 570,  80),
        new(SwitchId.R_Middle, 656, 225, 630,  65),
        new(SwitchId.R_Ring,   678, 233, 690,  80),
        new(SwitchId.R_Pinky,  700, 243, 750, 100),
    ];

    // Tapered finger: 20px wide at base (y=292), 14px at tip, rounded cap.
    // Middle finger: 67px tall (ratio ~3.4:1). Pinky: 49px. Thumb: 34px.
    private static string FingerPath(int cx, int tipY) =>
        $"M {cx - 10} 292 L {cx - 7} {tipY + 7} A 7 7 0 0 0 {cx + 7} {tipY + 7} L {cx + 10} 292 Z";

    private static (int X, int Y) GetArrowOffset(SwitchDirection dir) => dir switch
    {
        SwitchDirection.Up    => (0,  -22),
        SwitchDirection.Down  => (0,   22),
        SwitchDirection.Left  => (-22,  0),
        SwitchDirection.Right => (22,   0),
        SwitchDirection.Push  => (0,   18),
        _ => (0, 0)
    };
}
